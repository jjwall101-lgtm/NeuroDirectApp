rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return signedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /families/{familyId} {
      allow create: if signedIn();
      allow read, update: if isFamilyMember(familyId);

      match /members/{memberId} {
        allow create: if signedIn() && request.auth.uid == memberId;
        allow read: if isFamilyMember(familyId);
        allow update, delete: if signedIn() && request.auth.uid == memberId;
      }

      match /children/{childId} {
        allow create: if signedIn() && request.auth.uid == childId;
        allow read: if isFamilyMember(familyId);
        allow update, delete: if signedIn() && request.auth.uid == childId;

        match /calendar/{eventId} {
          allow read: if isFamilyMember(familyId);
          allow create, update, delete: if signedIn() && request.auth.uid == childId;
        }

        match /checkins/{checkinId} {
          allow read: if isFamilyMember(familyId);
          allow create, update, delete: if signedIn() && request.auth.uid == childId;
        }

        match /tasks/{taskId} {
          allow read: if isFamilyMember(familyId);
          allow create, update, delete: if signedIn() && request.auth.uid == childId;
        }
      }

      match /notifications/{notificationId} {
        allow read, update: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
