rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Family-code-only version.
    // Anonymous Firebase users can read/write family data after the app connects.
    // Keep family codes private.
    match /families/{familyId} {
      allow read, write: if signedIn();

      match /{document=**} {
        allow read, write: if signedIn();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
